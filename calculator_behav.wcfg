   </column_width_setting>
   <WVObjectSize size="6" />
   <wvobject fp_name="/vga_controller/clk_25MHz" type="logic">
      <obj_property name="ElementShortName">clk_25MHz</obj_property>
      <obj_property name="ObjectShortName">clk_25MHz</obj_property>
   </wvobject>
   <wvobject fp_name="/vga_controller/V_Count" type="other">
